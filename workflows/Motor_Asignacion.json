    {
      "parameters": {
        "jsCode": "const tutoresValidos = $('Filtrar Tutores').all().map(t => t.json.id_tutor);\nreturn items.filter(item => \n  tutoresValidos.includes(item.json.id_tutor) && \n  (item.json.estado || '').toLowerCase().trim() === \"libre\"\n);"
      },
      "type": "n8n-nodes-base.code",
