        "jsCode": "const materia = $('Procesar Materia').first().json.materia_seleccionada;\nreturn items.filter(item => \n  (item.json.estado_tutor || '').toLowerCase().trim() === \"activo\" && \n  (item.json.especialidad_materias || '').toLowerCase().trim() === (materia || '').toLowerCase().trim()\n);"
